package main

import (
	"fmt"
	"time"

	internalconfig "{{.ModuleName}}/internal/config"
	"{{.ModuleName}}/internal/contextkey"
	"{{.ModuleName}}/internal/db"
	internalhttp "{{.ModuleName}}/internal/http"
	"{{.ModuleName}}/internal/log"
	internalmessagebus "{{.ModuleName}}/internal/messagebus"
	commandhandler "{{.ModuleName}}/internal/temporal/command/handler"
	"{{.ModuleName}}/internal/storage"
	"{{.ModuleName}}/internal/temporal"
	config "bitbucket.org/csgot/helis-config-go"
	"bitbucket.org/csgot/helis-elasticlogrus/hook"
	"bitbucket.org/csgot/mp-platform-lib-temporalwrapper-go/v3/pkg/temporalwrapper"
	"bitbucket.org/csgot/mp-platform-lib-temporalwrapper-go/v3/pkg/temporalwrapper/logrushook"
	"bitbucket.org/csgot/mp-platform-lib-temporalwrapper-go/v3/pkg/temporalwrapper/processor"
	"bitbucket.org/csgot/mp-platform-lib-temporalwrapper-go/v3/pkg/temporalwrapper/workflow"
	"github.com/spf13/cobra"
